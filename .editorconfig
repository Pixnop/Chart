root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xml,csproj,props,targets,sln}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Style - PascalCase publics, camelCase locals, _camelCase private fields

# Constants are PascalCase regardless of accessibility. Declared first so it wins over the
# private-field rule below (a const is a 'field' kind, so that rule would otherwise force the
# _underscore style onto private consts, which is wrong for constants).
dotnet_naming_rule.constants_pascal_case.severity = warning
dotnet_naming_rule.constants_pascal_case.symbols = constant_fields
dotnet_naming_rule.constants_pascal_case.style = pascal_case_style

dotnet_naming_symbols.constant_fields.applicable_kinds = field
dotnet_naming_symbols.constant_fields.applicable_accessibilities = *
dotnet_naming_symbols.constant_fields.required_modifiers = const

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case

# Force file-scoped namespaces (C# 10+)
csharp_style_namespace_declarations = file_scoped:warning

# var preferences - explicit type where not obvious
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Sort using directives
dotnet_sort_system_directives_first = true

# Encourage init-only and records
dotnet_style_readonly_field = true:warning
csharp_style_prefer_primary_constructors = false:none
